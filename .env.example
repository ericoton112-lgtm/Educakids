# Variáveis de ambiente para o projeto Educakids
# Copie este arquivo para .env.local e preencha com suas credenciais

# Gemini AI API Key
GEMINI_API_KEY="sua_chave_da_api_gemini_aqui"

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="https://seuprojeto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua_chave_anonima_supabase_aqui"

# Outras configurações opcionais
NEXT_PUBLIC_APP_NAME="EducaKids"
NEXT_PUBLIC_APP_URL="https://educakids.vercel.app"